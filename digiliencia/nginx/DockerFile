FROM nginx:latest

# Remove default configuration
RUN rm /etc/nginx/conf.d/default.conf

# Copy our custom configuration
COPY digiliencia/nginx/nginx.conf /etc/nginx/nginx.conf

# Create directory for SSL certificates
RUN mkdir -p /etc/nginx/ssl

# The certificates should be mounted as volumes in docker-compose
# for production, but we can provide placeholders or instructions.

EXPOSE 80 443
