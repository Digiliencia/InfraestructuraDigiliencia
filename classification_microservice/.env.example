# Classification Microservice Environment Configuration
# Copy this file to .env and adjust the values as needed

# Service Configuration
CLASSIFICATION_SERVICE_HOST=0.0.0.0
CLASSIFICATION_SERVICE_PORT=8080

# Model Configuration
MODEL_NAME=roberta-large-mnli
DEVICE=auto  # auto, cpu, cuda, or specific GPU index (0, 1, etc.)

# API Configuration
MAX_TOPICS_LIMIT=20
DEFAULT_CONFIDENCE_THRESHOLD=0.1
REQUEST_TIMEOUT_SECONDS=120

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/classification_service.log
